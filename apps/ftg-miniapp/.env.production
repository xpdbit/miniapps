# ============================================================
# 生产环境配置 (用于 Taro --mode production 构建)
# ============================================================

# CloudBase 生产环境ID（部署前请替换为实际值）
CLOUDBASE_ENV_ID=YOUR_PRODUCTION_ENV_ID

# 混元AI服务 Endpoint（部署前请替换为实际值）
HUNYUAN_ENDPOINT=https://your-hunyuan-endpoint.example.com

# PP-ShiTuV2 食物识别 Endpoint（部署前请替换为实际值）
PPSHITU_ENDPOINT=https://your-ppshitu-endpoint.example.com
