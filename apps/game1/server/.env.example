# ─── Server ──────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
PUBLIC_URL="http://localhost:3004"

# ─── Database (MySQL via Prisma) ─────────────────────
# 注意: Prisma Schema (schema-game1.prisma) 读取 GAME1_DATABASE_URL
#       应用代码 (config/index.ts) 读取 DATABASE_URL
#       两个变量名需同时设置，值可相同
GAME1_DATABASE_URL="mysql://user:password@localhost:3306/game1"
DATABASE_URL="${GAME1_DATABASE_URL}"
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET="change-me-to-a-random-string"
JWT_EXPIRES_IN="7d"

# ─── WeChat Mini Program ────────────────────────────
WECHAT_APP_ID="wx_xxx"
WECHAT_APP_SECRET="xxx"

# ─── Admin ──────────────────────────────────────────
ADMIN_TOKEN="admin-token"

# ─── Logging ────────────────────────────────────────
LOG_LEVEL=info
