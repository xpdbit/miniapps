{
  "envId": "YOUR_CLOUDBASE_ENV_ID",
  "version": "2.0",
  "framework": {
    "name": "taro",
    "plugins": {
      "weapp": {
        "use": "@tarojs/plugin-platform-weapp"
      }
    }
  },
  "cloudrun": {
    "services": [
      {
        "name": "ppshituv2",
        "description": "PP-ShiTuV2 食物识别服务",
        "source": "docker/ppshituv2",
        "port": 8080,
        "cpu": 2,
        "mem": 4,
        "minNum": 1,
        "maxNum": 5,
        "envParams": "{\"PYTHONUNBUFFERED\":\"1\"}",
        "healthCheckPath": "/health",
        "policyType": "cpu",
        "policyThreshold": 60
      }
    ]
  }
}
