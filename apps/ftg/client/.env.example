# =============================================================================
# FTG 小程序前端 — 构建时环境变量模板
# 复制为 .env.dev / .env.production 并填入实际值
# 这些变量通过 Taro defineConstants 注入，仅在构建时生效
# =============================================================================
# 优先级: process.env.TARO_APP_XXX > domain.config.js 默认值
# =============================================================================

# API 基础地址（编译时注入，覆盖 domain.config.js）
# 开发:     http://localhost:3000/api/v1
# 真机调试: https://mnapp.top/api/ftl/api/v1
# 生产:     https://mnapp.top/api/ftl/api/v1
# TARO_APP_API_BASE=

# Mock 登录开关（开发时跳过 wx.login）
# TARO_APP_MOCK_AUTH=true

# CloudBase 环境 ID（仅云函数模式需要）
# CLOUDBASE_ENV_ID=

# QQ 地图密钥
# QQ_MAP_KEY=

# 混元 AI 服务 Endpoint（云函数模式）
# HUNYUAN_ENDPOINT=

# PP-ShiTuV2 食物识别 Endpoint（云函数模式）
# PPSHITU_ENDPOINT=
