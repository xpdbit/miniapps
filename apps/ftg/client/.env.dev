# 开发环境配置
# CloudBase 开发环境ID（请替换为实际值）
CLOUDBASE_ENV_ID=cloud1-xxxxxxxxx
# Mock 登录：TARO_APP_MOCK_AUTH=true 时跳过 wx.login()，使用 Mock code 登录
# 设置方式：在终端 export 或在 Taro 构建命令前加 TARO_APP_MOCK_AUTH=true
# 混元AI服务 Endpoint
HUNYUAN_ENDPOINT=https://your-hunyuan-endpoint
# PP-ShiTuV2 食物识别 Endpoint
PPSHITU_ENDPOINT=https://your-ppshitu-endpoint

# API 基础地址（构建时注入，覆盖 config/index.ts 中的默认值）
# 当前默认值由 domain.config.js 控制：
#   npm run dev:weapp       → 自动使用 http://localhost:3000/api/v1（Local DevTools）
#   npm run dev:weapp:remote → 使用 https://mnapp.top/api/ftl/api/v1（真机调试）
#   npm run build:weapp:prod → 使用 https://mnapp.top/api/ftl/api/v1（生产构建）
# 如需手动覆盖：$env:TARO_APP_API_BASE="https://your-domain/api/v1"
