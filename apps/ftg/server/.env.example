# ─── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=development
PUBLIC_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:3001"

# ─── Database (MySQL via Prisma) ─────────────────────
# 注意: Prisma Schema (schema-food-theme-generator.prisma) 读取 FTG_DATABASE_URL
#       应用代码 (config/env.ts) 读取 DATABASE_URL
#       两个变量名需同时设置，值可相同
FTG_DATABASE_URL="mysql://user:password@localhost:3306/food_theme_generator"
DATABASE_URL="${FTG_DATABASE_URL}"
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET=

# ─── WeChat Mini Program ────────────────────────────
WECHAT_APPID=
WECHAT_SECRET=

# ─── Alibaba Cloud OSS ──────────────────────────────
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# ─── AI ──────────────────────────────────────────────
# DashScope（通义千问）
DASHSCOPE_API_KEY=

# PP-ShiTuV2 食物识别微服务
PPSHITU_SERVICE_URL="http://localhost:5000"
# 模拟识别模式（本地开发时开启，跳过 PP-ShiTuV2）
RECOGNITION_MOCK_MODE=false

# AI 流水线最大并发数
PIPELINE_MAX_CONCURRENT=2

# ─── Storage ─────────────────────────────────────────
# 存储后端: local（本地）或 oss（阿里云 OSS）
STORAGE_PROVIDER=local

# ─── Security ────────────────────────────────────────
# AES-256-GCM 加密密钥（32字节 hex）
ENCRYPTION_KEY=
