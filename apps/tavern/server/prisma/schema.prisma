// ============================================================
// AI-Tavern Server Prisma Schema — miniapps DB → ai_tavern DB
// 基于: 原 apps/tavern/server/prisma/schema.prisma
// 变更: 去 SharedUser, creatorId/userId → userUuid, 加 user_profiles
// ============================================================

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")  // → ai_tavern 库
}

// ============================================================
// 枚举
// ============================================================

enum CardStatus {
  DRAFT
  PENDING
  PUBLISHED
  BANNED
  ARCHIVED
}

enum CardType {
  CHARACTER
  MECHANISM
  MAP
  BACKGROUND
}

enum MessageRole {
  user
  character
  system
}

enum UserTierType {
  FREE
  PAID
  TESTER
}

// ============================================================
// 1. Card — 角色卡 (creatorId → userUuid)
// ============================================================
model TavernCard {
  id               String     @id @default(uuid())
  userUuid         String     @map("user_uuid")
  name             String
  description      String     @db.VarChar(2000)
  avatar           String?    @map("avatar_url")
  cardType         CardType   @default(CHARACTER) @map("card_type")
  prompt           String?    @db.Text
  scenario         String?    @db.Text
  firstMsg         String?    @map("first_msg")
  tags             Json
  isOfficial       Boolean    @default(false) @map("is_official")
  status           CardStatus @default(DRAFT)
  locked           Boolean    @default(false)
  viewCount        Int        @default(0) @map("view_count")
  chatCount        Int        @default(0) @map("chat_count")
  likeCount        Int        @default(0) @map("like_count")
  favCount         Int        @default(0) @map("fav_count")
  cardSpec         Json       @default("{}") @map("card_spec")
  modelPreference  String?    @map("model_preference")
  temperature      Float?
  version          Int        @default(1)
  lastPublishedAt  DateTime?  @map("last_published_at")
  deletedAt        DateTime?  @map("deleted_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  likes     TavernCardLike[]
  favs      TavernCardFav[]
  chats     TavernChatSession[]
  revisions TavernCardRevision[]

  @@index([userUuid, status, cardType])
  @@index([status, cardType, likeCount(sort: Desc)])
  @@index([status, cardType, chatCount(sort: Desc)])
  @@index([status, cardType, createdAt(sort: Desc)])
  @@index([name])
  @@map("Card")
}

// ============================================================
// 2. CardLike — 点赞 (userId → userUuid)
// ============================================================
model TavernCardLike {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  userUuid  String   @map("user_uuid")
  createdAt DateTime @default(now()) @map("created_at")

  card TavernCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, userUuid])
  @@index([cardId, createdAt(sort: Desc)])
  @@map("CardLike")
}

// ============================================================
// 3. CardFav — 收藏 (userId → userUuid)
// ============================================================
model TavernCardFav {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  userUuid  String   @map("user_uuid")
  createdAt DateTime @default(now()) @map("created_at")

  card TavernCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, userUuid])
  @@index([userUuid, createdAt(sort: Desc)])
  @@map("CardFav")
}

// ============================================================
// 4. Persona — 用户人设 (userId → userUuid)
// ============================================================
model TavernPersona {
  id          String   @id @default(uuid())
  userUuid    String   @map("user_uuid")
  name        String
  description String?  @db.Text
  avatar      String?  @map("avatar_url")
  personality String?  @db.Text
  scenario    String?  @db.Text
  lore        String?  @db.Text
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  chatSessions TavernChatSession[]

  @@index([userUuid])
  @@map("Persona")
}

// ============================================================
// 5. ChatSession — 聊天会话 (userId → userUuid)
// ============================================================
model TavernChatSession {
  id            String   @id @default(uuid())
  userUuid      String   @map("user_uuid")
  cardId        String   @map("card_id")
  personaId     String?  @map("persona_id")
  title         String?
  modelKey      String?  @map("model_key")
  temperature   Float?
  config        Json?
  messageCount  Int      @default(0) @map("message_count")
  tokenCount    Int      @default(0) @map("token_count")
  pinned        Boolean  @default(false)
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  character TavernCard       @relation(fields: [cardId], references: [id])
  persona   TavernPersona?   @relation(fields: [personaId], references: [id])
  messages  TavernChatMessage[]

  @@index([userUuid, lastMessageAt(sort: Desc)])
  @@index([userUuid, pinned, updatedAt(sort: Desc)])
  @@map("ChatSession")
}

// ============================================================
// 6. ChatMessage — 聊天消息 (无 user 引用)
// ============================================================
model TavernChatMessage {
  id        String      @id @default(uuid())
  sessionId String      @map("session_id")
  role      MessageRole @default(user)
  content   String      @db.Text
  tokens    Int?
  createdAt DateTime    @default(now()) @map("created_at")

  session TavernChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("ChatMessage")
}

// ============================================================
// 7. ModerationLog — 审核日志 (operatorId → userUuid)
// ============================================================
model TavernModerationLog {
  id         String   @id @default(uuid())
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  action     String
  reason     String?
  userUuid   String?  @map("user_uuid")
  meta       Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([targetType, targetId])
  @@index([userUuid, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("ModerationLog")
}

// ============================================================
// 8. CardRevision — 卡片版本历史 (无 user 引用)
// ============================================================
model TavernCardRevision {
  id            String   @id @default(uuid())
  cardId        String   @map("card_id")
  revision      Int
  snapshot      Json
  changeSummary String?  @map("change_summary")
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  card TavernCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, revision(sort: Desc)])
  @@index([cardId, createdAt(sort: Desc)])
  @@map("CardRevision")
}

// ============================================================
// 9. ApiKey — 用户 AI Provider 密钥 (userId → userUuid)
// ============================================================
model TavernApiKey {
  id         String    @id @default(uuid())
  userUuid   String    @map("user_uuid")
  provider   String
  keyValue   String    @db.Text @map("key_value")
  baseUrl    String?   @db.Text @map("base_url")
  isActive   Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([userUuid, provider])
  @@map("ApiKey")
}

// ============================================================
// 10. UserTier — 用户等级与配额 (重构: 加 daily_quota 计数器)
// ============================================================
model TavernUserTier {
  userUuid        String       @id @map("user_uuid")
  tier            UserTierType @default(FREE)
  level           Int          @default(1)

  maxSessions     Int          @default(5)
  maxCharacters   Int          @default(3)
  maxPersonas     Int          @default(2)

  dailyQuotaMax   Int          @default(20) @map("daily_quota_max")
  dailyQuotaUsed  Int          @default(0)  @map("daily_quota_used")

  xp              Int          @default(0)
  xpToNext        Int          @default(100) @map("xp_to_next")

  permissions     Json         @default("{}")

  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@map("tavern_user_tiers")
}

// ============================================================
// 11. ModelMeta — 平台 AI 模型元数据 (不变)
// ============================================================
model TavernModelMeta {
  modelId     String       @id
  displayName String
  provider    String
  description String?
  icon        String?

  minTier   UserTierType @default(FREE)
  minLevel  Int          @default(1)
  quotaCost Int          @default(1)

  isActive  Boolean      @default(true)
  sortOrder Int          @default(0)

  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@index([minTier, sortOrder])
  @@map("ModelMeta")
}

// ============================================================
// 12. UserProfile — 用户偏好设置 (🆕)
// ============================================================
model TavernUserProfile {
  userUuid        String   @id @map("user_uuid")
  defaultModel    String?  @map("default_model")
  defaultTemp     Float?   @map("default_temp")
  preferredLocale String   @default("zh-CN") @map("preferred_locale")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("tavern_user_profiles")
}
