// ============================================================
// AI-Tavern Server Prisma Schema — miniapps DB
// 使用 camelCase 模型字段（兼容现有代码）
// @map 映射到 snake_case 数据库列名（兼容统一 DB 架构）
// ============================================================

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 枚举
// ============================================================

enum UserRole {
  USER
  ADMIN
}

enum CardStatus {
  DRAFT
  PENDING
  PUBLISHED
  BANNED
  ARCHIVED
}

enum CardType {
  CHARACTER
  MECHANISM
  MAP
  BACKGROUND
}

enum MessageRole {
  user
  character
  system
}

// ============================================================
// 1. shared_users — 统一用户身份
// ============================================================
model SharedUser {
  id            String    @id @default(uuid())
  uuid          String    @unique
  openid        String?   @unique
  nickname      String?
  avatar        String?
  dailyQuota    Int       @default(20)
  usedQuota     Int       @default(0)
  quotaDate     DateTime  @default(now())
  role          String    @default("USER")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tavernCards          TavernCard[]
  personas             TavernPersona[]
  chatSessions         TavernChatSession[]
  cardLikes            TavernCardLike[]
  cardFavs             TavernCardFav[]
  apiKeys              TavernApiKey[]
  moderationLogs       TavernModerationLog[]

  @@map("shared_users")
}

// ============================================================
// 2. tavern_cards — 角色卡片
// ============================================================
model TavernCard {
  id               String     @id @default(uuid())
  creatorId        String     @map("creator_id")
  name             String
  description      String     @db.VarChar(2000)
  avatar           String?    @map("avatar_url")
  cardType         CardType   @default(CHARACTER) @map("card_type")
  personality      String?    @db.Text
  scenario         String?    @db.Text
  firstMsg         String?    @map("first_msg")
  lore             String?    @db.Text
  systemPrompt     String?    @map("system_prompt")
  exampleDialogs   Json?      @map("example_dialogs")
  tags             Json
  nsfw             Boolean    @default(false)
  isOfficial       Boolean    @default(false) @map("is_official")
  status           CardStatus @default(DRAFT)
  locked           Boolean    @default(false)
  viewCount        Int        @default(0) @map("view_count")
  chatCount        Int        @default(0) @map("chat_count")
  likeCount        Int        @default(0) @map("like_count")
  favCount         Int        @default(0) @map("fav_count")
  cardSpec         Json       @default("{}") @map("card_spec")
  modelPreference  String?    @map("model_preference")
  temperature      Float?
  version          Int        @default(1)
  lastPublishedAt  DateTime?  @map("last_published_at")
  deletedAt        DateTime?  @map("deleted_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  creator   SharedUser          @relation(fields: [creatorId], references: [id])
  likes     TavernCardLike[]
  favs      TavernCardFav[]
  chats     TavernChatSession[]
  revisions TavernCardRevision[]

  @@index([creatorId, status, cardType])
  @@index([status, cardType, likeCount(sort: Desc)])
  @@index([status, cardType, chatCount(sort: Desc)])
  @@index([status, cardType, createdAt(sort: Desc)])
  @@index([name])
  @@map("tavern_cards")
}

// ============================================================
// 3. tavern_card_likes — 点赞
// ============================================================
model TavernCardLike {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  card TavernCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user SharedUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
  @@index([cardId, createdAt(sort: Desc)])
  @@map("tavern_card_likes")
}

// ============================================================
// 5. tavern_card_favs — 收藏
// ============================================================
model TavernCardFav {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  card TavernCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user SharedUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("tavern_card_favs")
}

// ============================================================
// 6. tavern_personas — 用户人设
// ============================================================
model TavernPersona {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?  @db.Text
  avatar      String?  @map("avatar_url")
  personality String?  @db.Text
  scenario    String?  @db.Text
  lore        String?  @db.Text
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user         SharedUser          @relation(fields: [userId], references: [id])
  chatSessions TavernChatSession[]

  @@index([userId])
  @@map("tavern_personas")
}

// ============================================================
// 7. tavern_chat_sessions — 聊天会话
// ============================================================
model TavernChatSession {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  characterId   String   @map("card_id")
  personaId     String?  @map("persona_id")
  title         String?
  modelKey      String?  @map("model_key")
  temperature   Float?
  config        Json?
  messageCount  Int      @default(0) @map("message_count")
  tokenCount    Int      @default(0) @map("token_count")
  pinned        Boolean  @default(false)
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user     SharedUser        @relation(fields: [userId], references: [id])
  character TavernCard      @relation(fields: [characterId], references: [id])
  persona  TavernPersona?    @relation(fields: [personaId], references: [id])
  messages TavernChatMessage[]

  @@index([userId, lastMessageAt(sort: Desc)])
  @@index([userId, pinned, updatedAt(sort: Desc)])
  @@map("tavern_chat_sessions")
}

// ============================================================
// 8. tavern_chat_messages — 聊天消息
// ============================================================
model TavernChatMessage {
  id        String      @id @default(uuid())
  sessionId String      @map("session_id")
  role      MessageRole @default(user)
  content   String      @db.Text
  tokens    Int?
  createdAt DateTime    @default(now()) @map("created_at")

  session TavernChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("tavern_chat_messages")
}

// ============================================================
// 9. tavern_moderation_logs — 审核日志
// ============================================================
model TavernModerationLog {
  id         String   @id @default(uuid())
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  action     String
  reason     String?
  operatorId String?  @map("operator_id")
  meta       Json?
  createdAt  DateTime @default(now()) @map("created_at")

  operator SharedUser? @relation(fields: [operatorId], references: [id])

  @@index([targetType, targetId])
  @@index([operatorId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("tavern_moderation_logs")
}

// ============================================================
// 10. tavern_card_revisions — 卡片版本历史
// ============================================================
model TavernCardRevision {
  id            String   @id @default(uuid())
  cardId        String   @map("card_id")
  revision      Int
  snapshot      Json
  changeSummary String?  @map("change_summary")
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  card TavernCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, revision(sort: Desc)])
  @@index([cardId, createdAt(sort: Desc)])
  @@map("tavern_card_revisions")
}

// ============================================================
// 11. tavern_api_keys — 用户 AI Provider 密钥
// ============================================================
model TavernApiKey {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  provider   String
  keyValue   String    @map("key_value")
  isActive   Boolean   @default(true) @map("is_active")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user SharedUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("tavern_api_keys")
}
