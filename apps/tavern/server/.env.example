# ─── Server ──────────────────────────────────────────
PORT=3002
NODE_ENV="development"
PUBLIC_URL="http://localhost:3002"
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# ─── Database (MySQL via Prisma) ─────────────────────
DATABASE_URL="mysql://root:password@localhost:3306/ai_tavern"
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET="your-jwt-secret-change-in-production"

# ─── WeChat Mini Program ────────────────────────────
WECHAT_APP_ID="your-wechat-app-id"
WECHAT_APP_SECRET="your-wechat-app-secret"

# ─── AI Providers ────────────────────────────────────
# DashScope（通义千问）
DASHSCOPE_API_KEY="your-dashscope-api-key"

# OpenCode Go（deepseek-v4-flash / deepseek-v4-pro / minimax-m2.5 等免费模型）
OPENCODE_API_KEY="sk-your-opencode-api-key"
OPENCODE_BASE_URL="https://opencode.ai/zen/go/v1"

# DeepSeek Free（回退用）
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"

# Dashboard Admin API URL（用于 AI Provider 配置同步）
ADMIN_API_URL="http://localhost:3001/api/v1"

# ─── Security ────────────────────────────────────────
# AES-256-GCM 加密密钥（32字节 hex）
ENCRYPTION_KEY="32-byte-hex-key-for-aes-256-gcm"

# ─── Admin ──────────────────────────────────────────
ADMIN_TOKEN="your-admin-token"
