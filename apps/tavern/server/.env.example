# ─── Server ──────────────────────────────────────────
PORT=3002
NODE_ENV="development"
PUBLIC_URL="http://localhost:3002"
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# ─── Database (MySQL via Prisma) ─────────────────────
DATABASE_URL="mysql://root:password@localhost:3306/ai_tavern"
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET="your-jwt-secret-change-in-production"

# ─── WeChat Mini Program ────────────────────────────
WECHAT_APP_ID="your-wechat-app-id"
WECHAT_APP_SECRET="your-wechat-app-secret"

# ─── AI Providers（兜底种子） ──────────────────────────
# NOTE: AI Provider 配置优先从 Dashboard Admin API 获取
# （GET /admin/ai-manager/public），以下环境变量仅作为
# Dashboard 不可用时的最后防线。管理 Provider 请在 Dashboard
# 的「AI 管理」页面操作。
#
# DashScope（通义千问）
DASHSCOPE_API_KEY="your-dashscope-api-key"

# OpenCode Go（deepseek-v4-flash / deepseek-v4-pro / minimax-m2.5 等免费模型）
OPENCODE_API_KEY="sk-your-opencode-api-key"
OPENCODE_BASE_URL="https://opencode.ai/zen/go/v1"

# DeepSeek Free（回退用）
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"

# Dashboard Admin API URL（用于 AI Provider 配置同步 + 限流配置）
ADMIN_API_URL="http://localhost:3001/api/v1"

# ─── Security ────────────────────────────────────────
# AES-256-GCM + PBKDF2 加密主密钥（32字节 hex）
# 用于：① 旧版用户 Key 加密 ② PBKDF2 盐加密的主密钥
ENCRYPTION_KEY="32-byte-hex-key-for-aes-256-gcm"

# ─── Admin ──────────────────────────────────────────
ADMIN_TOKEN="your-admin-token"
