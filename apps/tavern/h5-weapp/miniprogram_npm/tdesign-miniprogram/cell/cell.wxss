.t-float-left{float:left}.t-float-right{float:right}@keyframes tdesign-fade-out{from{opacity:1}to{opacity:0}}.t-cell{background-color:#fff;box-sizing:border-box;color:rgba(0,0,0,.9);display:flex;font-size:32rpx;line-height:48rpx;padding:24rpx 32rpx;position:relative;width:100%}.t-cell::after{border-bottom:1px solid #e7e7e7;bottom:0;box-sizing:border-box;content:" ";left:0;left:32rpx;pointer-events:none;position:absolute;right:0;transform:scaleY(.5)}.t-cell--borderless::after{display:none}.t-cell__description{color:rgba(0,0,0,.4);font-size:28rpx;line-height:44rpx}.t-cell__description-text{margin-top:8rpx}.t-cell__note{align-items:center;color:rgba(0,0,0,.4);display:flex;justify-content:flex-end;overflow:hidden}.t-cell__note,.t-cell__title{flex:1 1 auto}.t-cell__note:empty,.t-cell__title:empty{display:none}.t-cell__title-text{display:flex}.t-cell__left,.t-cell__right{align-items:center;display:flex;font-size:48rpx;line-height:48rpx}.t-cell__left{margin-right:16rpx}.t-cell__left-image{height:48rpx;width:48rpx}.t-cell__right{color:#bbb;margin-left:8rpx}.t-cell__right-icon{color:#bbb;font-size:48rpx;line-height:48rpx}.t-cell--hover.t-cell--hover-class{background-color:#f2f3f5}.t-cell--required{color:#e34d59;font-size:32rpx}.t-cell--middle{align-items:center}.t-cell--top{align-items:flex-start}.t-cell--bottom{align-items:flex-end}