.t-float-left{float:left}.t-float-right{float:right}@keyframes tdesign-fade-out{from{opacity:1}to{opacity:0}}.t-picker{background-color:#fff;font-size:32rpx;padding-bottom:env(safe-area-inset-bottom);position:relative}.t-picker__toolbar{align-items:center;box-shadow:inset 0 -1rpx 0 0 #e6e6e6;display:flex;height:96rpx;justify-content:space-between;overflow:hidden}.t-picker__title{color:#000;font-weight:500}.t-picker__cancel,.t-picker__confirm{align-items:center;display:flex;font-size:32rpx;height:100%;justify-content:center;padding:0 32rpx;user-select:none}.t-picker__cancel:active,.t-picker__confirm:active{opacity:.5}.t-picker__cancel{color:#444}.t-picker__confirm{color:#0052d9}.t-picker__main{display:flex;position:relative}.t-picker__mask{backface-visibility:hidden;background-image:linear-gradient(top,#fff,hsla(0,0%,100%,.4)),-webkit-linear-gradient(bottom,hsla(0,0%,100%,.92),hsla(0,0%,100%,.4));background-image:linear-gradient(180deg,hsla(0,0%,100%,.92),hsla(0,0%,100%,.4)),linear-gradient(0deg,hsla(0,0%,100%,.92),hsla(0,0%,100%,.4));background-position:top,bottom;background-repeat:no-repeat;background-size:100% 160rpx;height:100%;left:0;margin:0 auto;pointer-events:none;position:absolute;top:0;transform:translateZ(0);width:100%;z-index:3}.t-picker__indicator{height:80rpx;left:0;pointer-events:none;position:absolute;top:160rpx;width:100%;z-index:3}.t-picker__indicator::before{border-top:1rpx solid #e6e6e6;color:#e6e6e6;content:" ";height:1rpx;left:0;position:absolute;right:0;top:0;transform-origin:0 0}.t-picker__indicator::after{border-bottom:1rpx solid #e6e6e6;bottom:0;color:#e6e6e6;content:" ";height:1rpx;left:0;position:absolute;right:0;transform-origin:0 100%}