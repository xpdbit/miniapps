.t-float-left{float:left}.t-float-right{float:right}@keyframes tdesign-fade-out{from{opacity:1}to{opacity:0}}.t-swiper-nav__dots,.t-swiper-nav__dots-bar{bottom:20rpx;display:flex;flex-direction:row;left:50%;position:absolute;transform:translateX(-50%)}.t-swiper-nav__dots-bar-item,.t-swiper-nav__dots-item{background:hsla(0,0%,100%,.55);border-radius:50%;height:12rpx;margin:0 10rpx;transition:all .4s ease-in;width:12rpx}.t-swiper-nav__dots-bar-item.t-is-active,.t-swiper-nav__dots-item.t-is-active{background-color:#fff}.t-swiper-nav__dots-bar-item.t-is-active{background-color:#fff;border-radius:6rpx;width:40rpx}.t-swiper-nav--vertical .t-swiper-nav__dots,.t-swiper-nav--vertical .t-swiper-nav__dots-bar{bottom:auto;flex-direction:column;left:auto;right:20rpx;top:50%;transform:translateY(-50%)}.t-swiper-nav--vertical .t-swiper-nav__dots-bar-item,.t-swiper-nav--vertical .t-swiper-nav__dots-item{margin:10rpx 0}.t-swiper-nav--vertical .t-swiper-nav__dots-bar-item.t-is-active{height:40rpx;width:12rpx}.t-swiper-nav__fraction{background:rgba(0,0,0,.4);border-radius:20rpx;bottom:20rpx;color:#fff;font-size:24rpx;height:40rpx;line-height:40rpx;padding:0 20rpx;position:absolute;right:20rpx}.t-swiper-nav__btn--next,.t-swiper-nav__btn--prev{background:rgba(0,0,0,.4);border-radius:50%;height:40rpx;position:absolute;top:50%;transform:translateY(-50%);width:40rpx}.t-swiper-nav__btn--next::after,.t-swiper-nav__btn--prev::after{border-color:#fff;border-style:solid;content:"";display:block;height:12rpx;left:50%;position:absolute;top:50%;width:12rpx}.t-swiper-nav__btn--prev{left:30rpx}.t-swiper-nav__btn--prev::after{border-width:2rpx 0 0 2rpx;margin-left:4rpx;transform:translate(-50%,-50%) rotate(-45deg)}.t-swiper-nav__btn--next{right:30rpx}.t-swiper-nav__btn--next::after{border-width:2rpx 2rpx 0 0;margin-left:-4rpx;transform:translate(-50%,-50%) rotate(45deg)}