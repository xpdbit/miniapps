.t-float-left{float:left}.t-float-right{float:right}@keyframes tdesign-fade-out{from{opacity:1}to{opacity:0}}.limit-title-row{display:-webkit-box;-webkit-box-orient:vertical;overflow:hidden}.t-radio{background:#fff;display:flex;flex-direction:row;font-size:32rpx;padding:32rpx;position:relative}.t-radio--right{flex-direction:row-reverse}.t-radio__icon{width:48rpx}.t-radio__icon--left{margin-right:20rpx}.t-radio__icon--right{margin-left:auto}.t-radio__image{line-height:48rpx}.t-radio-icon__image{height:48rpx;vertical-align:sub;width:48rpx}.t-radio__btn{color:#dcdcdc;display:block;font-size:48rpx;height:48rpx;line-height:40rpx}.t-radio__content{flex:1;line-height:48rpx;margin-right:10px}.t-radio__content--disabled{color:rgba(0,0,0,.26);cursor:not-allowed}.t-radio__title{display:-webkit-box;-webkit-box-orient:vertical;overflow:hidden}.t-radio__description{color:rgba(0,0,0,.4);display:-webkit-box;-webkit-box-orient:vertical;font-size:28rpx;line-height:44rpx;overflow:hidden}.t-radio-is-checked{color:#0052d9}.t-radio-is-disabled{color:#dcdcdc;cursor:not-allowed}.t-radio__border{border-top:1rpx solid #e7e7e7;bottom:0;display:block;position:absolute;width:100%}.t-radio__border--left{left:80rpx;width:calc(100% - 80rpx)}.t-radio__border--right{right:80rpx;width:calc(100% - 80rpx)}