.t-float-left{float:left}.t-float-right{float:right}@keyframes tdesign-fade-out{from{opacity:1}to{opacity:0}}.t-message{align-items:center;background:#fff;border-radius:8rpx;box-shadow:0 1px 4px 0 rgba(0,0,0,.2);box-sizing:border-box;color:#0052d9;display:flex;font-size:28rpx;justify-content:flex-start;left:0;line-height:1;opacity:0;padding:24rpx 32rpx;position:fixed;right:0;top:0;z-index:5000}.t-message__text{display:inline-block}.t-message__text-wrap{flex:1 1 auto;line-height:44rpx;overflow-x:hidden;text-overflow:ellipsis}.t-message__text-nowrap{white-space:nowrap;word-break:keep-all}.t-message--info{color:#0052d9}.t-message--success{color:#00a870}.t-message--warning{color:#ed7b2f}.t-message--error{color:#e34d59}.t-message .t-message__icon--left{margin-right:16rpx}.t-message .t-message__btn--right,.t-message .t-message__icon--right{flex:0 0 auto;margin-left:16rpx}.t-message .t-message__btn--right{background:transparent;border-color:inherit;border-radius:8rpx;color:inherit;font-size:inherit;height:44rpx;line-height:inherit;line-height:44rpx;min-height:0}