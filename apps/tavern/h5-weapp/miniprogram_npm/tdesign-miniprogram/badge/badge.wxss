.t-float-left{float:left}.t-float-right{float:right}@keyframes tdesign-fade-out{from{opacity:1}to{opacity:0}}.t-badge{display:inline-block;position:relative}.t-badge--basic{background-color:#e34d59;color:#fff;display:inline-block;font-size:20rpx;font-weight:400;height:32rpx;line-height:32rpx;padding:0 8rpx;text-align:center;z-index:100}.t-badge--dot{border-radius:8rpx;height:20rpx;min-width:20rpx;padding:0}.t-badge--small{transform:translate(50%,-50%) scale(.75)}.t-badge--circle{border-radius:16rpx}.t-badge--round{border-radius:8rpx}.t-badge__ribbon--outer{position:absolute;right:0;top:0}.t-badge--ribbon{padding:0;transform:rotate(45deg)}.t-badge--ribbon::before{border-bottom:32rpx solid #e34d59;border-left:32rpx solid transparent;bottom:0;content:"";height:0;left:-32rpx;position:absolute;width:0}.t-badge--ribbon::after{border-bottom:32rpx solid #e34d59;border-right:32rpx solid transparent;bottom:0;content:"";height:0;position:absolute;right:-32rpx;width:0}.t-badge__content:not(:empty) + .t-has-count{position:absolute;right:0;top:0;transform:translate(50%,-50%)}