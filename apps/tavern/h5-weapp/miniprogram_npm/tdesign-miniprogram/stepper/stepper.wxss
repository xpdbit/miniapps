.t-float-left{float:left}.t-float-right{float:right}@keyframes tdesign-fade-out{from{opacity:1}to{opacity:0}}.t-stepper{align-items:center;display:flex}.t-stepper.t-stepper--normal .t-stepper__input{background:0;border:0;color:#000;display:block;font-size:16px;height:48rpx;text-align:center;vertical-align:top}.t-stepper.t-stepper--normal .t-stepper__minus,.t-stepper.t-stepper--normal .t-stepper__plus{box-sizing:border-box;display:block;height:48rpx;padding-top:5rpx}.t-stepper.t-stepper--pure .t-stepper__input{background-color:#f1f2f5;border-radius:2px;font-size:24rpx;height:48rpx;margin:0 5px;text-align:center}.t-stepper.t-stepper--pure .t-stepper__minus,.t-stepper.t-stepper--pure .t-stepper__plus{background-color:#f1f2f5;border-radius:2px;box-sizing:border-box;height:48rpx;padding:5rpx 10rpx}.t-stepper .t-is-disabled .t-stepper__input{color:rgba(0,0,0,.26)}