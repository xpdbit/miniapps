{
  "name": "tavern-miniapp",
  "version": "1.0.0",
  "description": "AI Tavern - 角色卡聊天小程序",
  "private": true,
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp --mode development",
    "build:weapp:prod": "taro build --type weapp --mode production",
    "predev:weapp": "node -e \"const fs=require('fs');const d='dist-weapp';const rm=r=>{try{fs.rmSync(r,{recursive:true,force:true})}catch(e){if(e.code==='EBUSY'){const ents=fs.readdirSync(r,{withFileTypes:true});for(const e of ents){const p=r+'/'+e.name;e.isDirectory()?rm(p):fs.unlinkSync(p)}try{fs.rmdirSync(r)}catch(e2){console.error('rmdir failed:',e2.message)}}else{console.error('rm failed:',e.message)}}};if(fs.existsSync(d)){rm(d)};console.log('cleaned '+d)\"",
    "dev:weapp": "taro build --type weapp --watch --mode development",
    "dev:weapp:local": "set TARO_APP_API_BASE=http://localhost:3002/api/v1/tavern && taro build --type weapp --watch --mode development",
    "dev:weapp:remote": "set TARO_APP_API_BASE=https://mnapp.top/api/v1/tavern && taro build --type weapp --watch --mode development",
    "build:h5": "taro build --type h5 --mode development",
    "predev:h5": "node -e \"const fs=require('fs');const d='dist-h5';fs.rmSync(d,{recursive:true,force:true});console.log('cleaned '+d)\"",
    "dev:h5": "taro build --type h5 --watch --mode development",
    "dev:h5:local": "set TARO_APP_API_BASE=http://localhost:3002/api/v1/tavern && taro build --type h5 --watch --mode development",
    "dev:h5:remote": "set TARO_APP_API_BASE=https://mnapp.top/api/v1/tavern && taro build --type h5 --watch --mode development",
    "dev:web": "npm run dev:h5:local",
    "build:web": "taro build --type h5 --mode production",
    "build:h5:prod": "taro build --type h5 --mode production",
    "generate-icons": "node scripts/generate-icons.mjs",
    "lint": "eslint src/**/*.{ts,tsx} --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,scss,css}'",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@tarojs/components": "4.0.13",
    "@tarojs/plugin-framework-react": "4.0.13",
    "@tarojs/plugin-html": "4.0.13",
    "@tarojs/plugin-platform-h5": "4.0.13",
    "@tarojs/plugin-platform-weapp": "4.0.13",
    "@tarojs/react": "4.0.13",
    "@tarojs/runtime": "4.0.13",
    "@tarojs/taro": "4.0.13",
    "core-js-pure": "^3.49.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.17",
    "@tarojs/cli": "4.0.13",
    "@tarojs/webpack5-runner": "4.0.13",
    "@types/react": "^18.3.0",
    "@types/webpack-env": "^1.18.0",
    "@types/wechat-miniprogram": "^3.4.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-preset-taro": "4.0.13",
    "eslint": "^8.57.0",
    "eslint-config-taro": "4.0.13",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "html-webpack-plugin": "^5.6.7",
    "postcss": "^8.4.38",
    "prettier": "^3.2.0",
    "sass": "^1.72.0",
    "typescript": "^5.4.0",
    "webpack": "5.91.0"
  }
}
