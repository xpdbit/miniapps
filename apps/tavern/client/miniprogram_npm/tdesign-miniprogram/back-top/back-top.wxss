.t-float-left{float:left}.t-float-right{float:right}@keyframes tdesign-fade-out{from{opacity:1}to{opacity:0}}.t-back-top{align-items:center;background-color:transparent;box-sizing:border-box;display:flex;flex-direction:column;height:auto;justify-content:center;overflow:hidden;transition:height .2s}.t-back-top.t-is-fixed{bottom:133rpx;position:fixed;right:32rpx}.t-back-top.t-is-round,.t-back-top.t-is-round-dark{border-radius:50%;height:96rpx;width:96rpx}.t-back-top.t-is-round .t-back-top__icon,.t-back-top.t-is-round-dark .t-back-top__icon{background-color:transparent;border-radius:0;margin:0}.t-back-top.t-is-round .t-back-top__text,.t-back-top.t-is-round-dark .t-back-top__text{margin-top:0;padding:0}.t-back-top.t-is-half-round,.t-back-top.t-is-round{background-color:#fff;border:1rpx solid #ddd;color:#333}.t-back-top.t-is-half-round .t-back-top__icon,.t-back-top.t-is-half-round .t-back-top__text,.t-back-top.t-is-round .t-back-top__icon,.t-back-top.t-is-round .t-back-top__text{color:#333}.t-back-top.t-is-half-round-dark,.t-back-top.t-is-round-dark{background-color:#000;color:#fff}.t-back-top.t-is-half-round-dark .t-back-top__icon,.t-back-top.t-is-half-round-dark .t-back-top__text,.t-back-top.t-is-round-dark .t-back-top__icon,.t-back-top.t-is-round-dark .t-back-top__text{color:#fff}.t-back-top.t-is-half-round,.t-back-top.t-is-half-round-dark{border-radius:120rpx 0 0 120rpx;flex-direction:row;height:80rpx;right:0;width:120rpx}.t-back-top.t-is-half-round .t-back-top__icon,.t-back-top.t-is-half-round-dark .t-back-top__icon{background-color:transparent;border-radius:0;margin:0}.t-back-top.t-is-half-round .t-back-top__text,.t-back-top.t-is-half-round-dark .t-back-top__text{margin-left:8rpx;padding:0;width:2em}.t-back-top__text{color:#666;font-size:20rpx;line-height:24rpx}.t-back-top__icon{align-items:center;color:#666;display:flex;font-size:32rpx;justify-content:center}