.t-float-left{float:left}.t-float-right{float:right}@keyframes tdesign-fade-out{from{opacity:1}to{opacity:0}}.t-search{align-items:center;display:flex;justify-content:space-between}.t-search__label{color:rgba(0,0,0,.9);padding:8rpx}.t-search__input-box{align-items:center;background:#f3f3f3;border:2rpx solid #f3f3f3;box-sizing:border-box;display:flex;flex:1;height:80rpx;padding:16rpx 24rpx}.t-search__input-box.t-is-focused{border-color:#f3f3f3}.t-search__input-box--round{border-radius:80rpx/2}.t-search__input-box--square{border-radius:8rpx}.t-search__input-box--center.t-not-focused{justify-content:center}.t-search__input-box .t-input__keyword{color:rgba(0,0,0,.9);display:inline-block;flex:1;font-size:32rpx;padding-left:16rpx}.t-search__input-box .t-icon{color:rgba(0,0,0,.26)}.t-search__search-action{color:rgba(0,0,0,.26);font-size:32rpx;margin-left:30rpx}.t-search__placeholder-center{color:rgba(0,0,0,.26);font-size:32rpx;margin-left:16rpx}.t-search__placeholder{color:rgba(0,0,0,.26)}