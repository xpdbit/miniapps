.t-float-left{float:left}.t-float-right{float:right}@keyframes tdesign-fade-out{from{opacity:1}to{opacity:0}}.t-checkbox{background:#fff;display:flex;flex-direction:row;font-size:32rpx;padding:32rpx;position:relative}.t-checkbox .limit-title-row{display:-webkit-box;-webkit-box-orient:vertical;overflow:hidden}.t-checkbox .image-center{position:absolute;top:50%;transform:translateY(-50%)}.t-checkbox__icon-left{margin-right:20rpx;width:40rpx}.t-checkbox__icon-right{display:contents;position:absolute;right:0;top:50%;transform:translateY(-50%)}.t-checkbox__icon-image{height:48rpx;vertical-align:sub;width:48rpx}.t-checkbox__icon{line-height:48rpx}.t-checkbox__btn{color:#dcdcdc;display:block;font-size:48rpx;line-height:40rpx;width:48rpx}.t-checkbox__content{flex:1;line-height:48rpx;margin-right:10px}.t-checkbox__title{display:-webkit-box;-webkit-box-orient:vertical;overflow:hidden}.t-checkbox__description{color:rgba(0,0,0,.4);display:-webkit-box;-webkit-box-orient:vertical;font-size:28rpx;line-height:44rpx;overflow:hidden}.t-checkbox__btn.t-is-checked{color:#0052d9}.t-checkbox__btn.t-is-disabled{color:#dcdcdc;cursor:not-allowed}.t-checkbox__content.t-is-disabled{color:rgba(0,0,0,.26);cursor:not-allowed}.t-checkbox__bordered{border-top:1rpx solid #e7e7e7;bottom:0;display:block;position:absolute;width:100%}.t-checkbox__bordered--left{left:80rpx;width:calc(100% - 80rpx)}.t-checkbox__bordered--right{right:80rpx;width:calc(100% - 80rpx)}