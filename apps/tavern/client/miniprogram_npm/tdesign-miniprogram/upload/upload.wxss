.t-float-left{float:left}.t-float-right{float:right}@keyframes tdesign-fade-out{from{opacity:1}to{opacity:0}}.t-upload .t-upload__grid-content{background:#f3f3f3;padding:0}.t-upload .t-upload__grid-file{position:relative}.t-upload__add-icon{align-items:center;background-color:#f3f3f3;color:#a6a6a6;display:flex;height:100%;justify-content:center;width:100%}.t-upload__thumbnail{height:100%;max-height:100%;overflow:hidden;width:100%}.t-upload__wrapper{position:relative}.t-upload__close-btn{background-color:rgba(0,0,0,.6);font-size:21rpx;height:32rpx;line-height:32rpx;position:absolute;right:0;top:0;width:32rpx;z-index:2}.t-upload .t-upload__progress-mask{align-items:center;background-color:rgba(0,0,0,.6);display:flex;height:100%;justify-content:center;left:0;position:absolute;top:0;width:100%}.t-upload .t-upload__progress-mask .t-upload__progress-failed{color:#ff4646;font-size:24rpx}.t-upload .t-upload__progress-mask .t-upload__progress-value{color:#fff;font-size:24rpx}