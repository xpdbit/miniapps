.t-float-left{float:left}.t-float-right{float:right}@keyframes tdesign-fade-out{from{opacity:1}to{opacity:0}}page .t-dialog{background-color:#fff;border-radius:16rpx;overflow:hidden;width:644rpx}page .t-dialog__content{box-sizing:border-box;display:flex;flex-direction:column;font-size:32rpx;justify-content:center;line-height:1.5;max-height:776rpx;min-height:176rpx;padding:64rpx 48rpx}page .t-dialog__header{color:#000;font-size:32rpx;font-weight:700;line-height:1.5;text-align:center}page .t-dialog__body{overflow-y:scroll;text-align:center;-webkit-overflow-scrolling:touch;color:#888;font-size:32rpx;margin-top:32rpx}page .t-dialog__body--without-title{margin-top:0}page .t-dialog__body-text{word-wrap:break-word}page .t-dialog__body--left{text-align:left}page .t-dialog__body--right{text-align:right}page .t-dialog__footer{display:flex}page .t-dialog__footer--column{flex-flow:column-reverse}page .t-dialog__footer--column .t-dialog__button{width:100%}page .t-dialog__button{align-items:center;background-color:#fff;border:1rpx solid #e7e7e7;border-bottom:0;border-left:0;border-radius:0;display:flex;flex:1;font-size:32rpx;height:112rpx;justify-content:center;line-height:112rpx;padding:0 48rpx;width:644rpx}page .t-dialog__button-half{width:644rpx/2}page .t-dialog__button-confirm{color:#0052d9;font-weight:700}page .t-dialog__button-cancel{color:#000;font-weight:400}page .t-dialog__button-bounce-enter{opacity:0;transform:translate3d(-50%,-50%,0) scale(.7)}page .t-dialog__button-bounce-leave-active{opacity:0;transform:translate3d(-50%,-50%,0) scale(.9)}page .t-dialog__button::after{border-color:rgba(0,0,0,.05);border-radius:0}page .t-dialog__button--active,page .t-dialog__button:active{background-color:rgba(0,0,0,.05)}page .t-dialog__text + .t-dialog__input{margin-top:48rpx}page .t-dialog__input{background-color:#f0f0f0;border-radius:16rpx/2;box-sizing:border-box;color:#000;font-size:32rpx;height:96rpx;line-height:1.5;margin-top:24rpx;padding:24rpx;text-align:left;width:100%}page 