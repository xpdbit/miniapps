.t-float-left{float:left}.t-float-right{float:right}@keyframes tdesign-fade-out{from{opacity:1}to{opacity:0}}.t-avatar{align-items:center;border:0 solid;border-radius:999rpx;box-sizing:border-box;display:flex;font-size:28rpx;font-weight:600;justify-content:center;overflow:hidden}.t-avatar__wrapper{float:left;position:relative}.t-avatar__wrapper t-badge{position:absolute}.t-avatar__wrapper .t-badge__round{right:-10%;top:-10%}.t-avatar__wrapper .t-badge__circle{right:-5%;top:-5%}.t-avatar.t-size-l{font-size:36rpx;font-weight:600;height:128rpx;width:128rpx}.t-avatar.t-size-m{font-size:32rpx;font-weight:600;height:96rpx;width:96rpx}.t-avatar.t-size-s{font-size:24rpx;font-weight:600;height:64rpx;width:64rpx}.t-avatar .t-image,.t-avatar__image{height:100%;width:100%}.t-avatar--circle{border-radius:999rpx;overflow:hidden}.t-avatar--round{border-radius:10rpx;overflow:hidden}.t-avatar__icon,.t-avatar__text{align-items:center;border-radius:999rpx;display:flex;height:100%;justify-content:center;width:100%}