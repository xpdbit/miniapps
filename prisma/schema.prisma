// ============================================================
// 统一 Prisma Schema — miniapps DB (30 表，UUID v7 + JSON flex)
// 模型覆盖: FTG (9) + Dashboard (3) + shared (1)
// ============================================================

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 枚举
// ============================================================

enum FoodType {
  grain      @map("grain")
  vegetable  @map("vegetable")
  fruit      @map("fruit")
  meat       @map("meat")
  seafood    @map("seafood")
  dairy      @map("dairy")
  nut        @map("nut")
  snack      @map("snack")
  beverage   @map("beverage")
  seasoning  @map("seasoning")
  dish       @map("dish")
  other      @map("other")
}

enum PipelineStatus {
  pending      @map("pending")
  recognizing  @map("recognizing")
  recognized   @map("recognized")
  generating   @map("generating")
  composing    @map("composing")
  completed    @map("completed")
  failed       @map("failed")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  active
  disabled
}

enum AdminRole {
  super_admin
  admin
  viewer
}

enum AdminStatus {
  active
  disabled
}

enum ProjectStatus {
  active
  inactive
}

// ============================================================
// 1. shared_users — 统一用户身份
// ============================================================
model SharedUser {
  id               String     @id @default(uuid())
  uuid             String     @unique
  openid           String?    @unique
  phone            String?    @unique
  phone_country    String?    @default("86")
  phone_verified   Boolean    @default(false)
  phone_verified_at DateTime?
  nickname         String?
  avatar_url       String?
  role             UserRole   @default(USER)
  status           UserStatus @default(active)
  meta             Json?
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt

  ftgFoodRecords      FtgFoodRecord[]
  ftgCheckins         FtgCheckin[]
  ftgUserAchievements FtgUserAchievement[]
  ftgPipelines        FtgPipelineStatus[]
  ftgFavorites        FtgFavorite[]

  @@index([uuid])
  @@index([openid])
  @@index([nickname])
  @@map("shared_users")
}

// ============================================================
// 2. ftg_food_records — 食物记录
// ============================================================
model FtgFoodRecord {
  id         String    @id @default(uuid())
  user_id    String
  food_type  FoodType
  theme_id   String?
  is_public  Boolean   @default(true)
  is_deleted Boolean   @default(false)
  deleted_at DateTime?
  data       Json
  version    Int       @default(1)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  user      SharedUser   @relation(fields: [user_id], references: [id])
  checkin   FtgCheckin?
  favorites FtgFavorite[]

  @@index([user_id, created_at(sort: Desc)])
  @@index([food_type])
  @@index([theme_id])
  @@index([is_public, is_deleted, created_at(sort: Desc)])
  @@map("ftg_food_records")
}

// ============================================================
// 3. ftg_checkins — 打卡记录
// ============================================================
model FtgCheckin {
  id             String   @id @default(uuid())
  user_id        String
  food_record_id String   @unique
  location_name  String?
  latitude       Float?
  longitude      Float?
  checkin_date   DateTime @db.Date
  streak_count   Int      @default(0)
  created_at     DateTime @default(now())

  user       SharedUser    @relation(fields: [user_id], references: [id])
  foodRecord FtgFoodRecord @relation(fields: [food_record_id], references: [id])

  @@index([user_id, checkin_date(sort: Desc)])
  @@map("ftg_checkins")
}

// ============================================================
// 4. ftg_achievements — 成就定义
// ============================================================
model FtgAchievement {
  id             String   @id @default(uuid())
  achievement_id String   @unique
  name           String
  description    String
  icon_url       String?
  condition_type String
  condition_value Int
  condition_param String?
  theme_id       String?
  created_at     DateTime @default(now())

  userAchievements FtgUserAchievement[]

  @@map("ftg_achievements")
}

// ============================================================
// 5. ftg_user_achievements — 用户成就关联
// ============================================================
model FtgUserAchievement {
  id             String   @id @default(uuid())
  user_id        String
  achievement_id String
  unlocked_at    DateTime @default(now())
  progress       Int      @default(0)
  is_unlocked    Boolean  @default(false)

  user        SharedUser     @relation(fields: [user_id], references: [id])
  achievement FtgAchievement @relation(fields: [achievement_id], references: [achievement_id])

  @@unique([user_id, achievement_id])
  @@map("ftg_user_achievements")
}

// ============================================================
// 6. ftg_themes — 主题定义
// ============================================================
model FtgTheme {
  id               String   @id @default(uuid())
  theme_id         String   @unique
  project_id       String   @default("ftg")
  name             String
  short_name       String?  @unique
  game_name        String
  description      String?
  data             Json
  preview_image_url String?
  is_active        Boolean  @default(true)
  sort_order       Int      @default(0)
  usage_count      Int      @default(0)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@index([project_id, is_active])
  @@index([short_name])
  @@map("ftg_themes")
}

// ============================================================
// 7. ftg_theme_classes — CSS Class 定义
// ============================================================
model FtgThemeClass {
  id          String   @id @default(uuid())
  class_id    String   @unique
  project_id  String   @default("ftg")
  name        String
  category    String   @default("official")
  data        Json
  description String?
  creator_id  String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([project_id, category])
  @@map("ftg_theme_classes")
}

// ============================================================
// 8. ftg_theme_usage_logs — 主题使用日志
// ============================================================
model FtgThemeUsageLog {
  id         String   @id @default(uuid())
  theme_id   String
  record_id  String
  user_id    String
  created_at DateTime @default(now())

  @@unique([theme_id, record_id])
  @@index([theme_id, created_at(sort: Desc)])
  @@map("ftg_theme_usage_logs")
}

// ============================================================
// 9. ftg_pipeline_statuses — AI 流水线状态
// ============================================================
model FtgPipelineStatus {
  id          String         @id @default(uuid())
  user_id     String
  pipeline_id String         @unique
  status      PipelineStatus @default(pending)
  progress    Int            @default(0)
  image_url   String?
  theme_id    String?
  data        Json?
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  user SharedUser @relation(fields: [user_id], references: [id])

  @@map("ftg_pipeline_statuses")
}

// ============================================================
// 10. ftg_favorites — 收藏
// ============================================================
model FtgFavorite {
  id         String   @id @default(uuid())
  user_id    String
  record_id  String
  created_at DateTime @default(now())

  user      SharedUser    @relation(fields: [user_id], references: [id])
  foodRecord FtgFoodRecord @relation(fields: [record_id], references: [id])

  @@unique([user_id, record_id])
  @@index([user_id, created_at(sort: Desc)])
  @@map("ftg_favorites")
}

// ============================================================
// 11. dashboard_admin_users — 管理员账号
// ============================================================
model DashboardAdminUser {
  id            String      @id @default(uuid())
  username      String      @unique
  password_hash String
  phone         String?     @unique
  role          AdminRole   @default(admin)
  status        AdminStatus @default(active)
  meta          Json?
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  auditLogs DashboardAuditLog[]

  @@map("dashboard_admin_users")
}

// ============================================================
// 12. dashboard_projects — 项目注册
// ============================================================
model DashboardProject {
  id           String        @id @default(uuid())
  slug         String        @unique
  name         String
  api_base_url String
  description  String?
  status       ProjectStatus @default(active)
  meta         Json?
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  @@map("dashboard_projects")
}

// ============================================================
// 13. dashboard_audit_logs — 管理审计日志
// ============================================================
model DashboardAuditLog {
  id          String   @id @default(uuid())
  admin_id    String
  action      String
  target_type String?
  target_id   String?
  details     Json?
  ip_address  String?
  created_at  DateTime @default(now())

  admin DashboardAdminUser @relation(fields: [admin_id], references: [id])

  @@index([admin_id, created_at(sort: Desc)])
  @@index([target_type, target_id])
  @@index([created_at(sort: Desc)])
  @@map("dashboard_audit_logs")
}
