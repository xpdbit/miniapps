# =============================================================================
# Dashboard — 环境变量模板（开发/生产通用）
# =============================================================================

# ─── 构建时变量（Vite 前端编译注入） ─────────────────
# VITE_ 前缀的变量会在构建时注入到前端代码
VITE_API_BASE_URL=http://localhost:3000/api/v1

# ─── Admin API 服务配置 ──────────────────────────────
# Dashboard Admin API 服务器（Express, 端口 3001）
ADMIN_PORT=3001
JWT_SECRET=your-admin-jwt-secret

# Agent 调试通道认证密钥
AGENT_API_KEY=
# 超级管理员种子账号（通过 POST /api/admin/agent/seed-admin 初始化）
ADMIN_SEED_USERNAME=admin
# ⚠ 默认密码 Admin123! 为弱密码，生产环境必须修改
ADMIN_SEED_PASSWORD=Admin123!

# ─── 数据库（Prisma / miniapps 公用库） ──────────────
MINIAPPS_DATABASE_URL=mysql://root:password@localhost:3306/miniapps

# ─── 代理目标（本地开发） ────────────────────────────
# Game1: Dashboard 通过代理访问 game1-server 管理 API
GAME1_API_URL=http://localhost:3004/api/v1/game1
# Game1 Admin Token（需与 game1-server 的 ADMIN_TOKEN 一致）
GAME1_ADMIN_TOKEN=

# Tavern: Dashboard 通过代理访问 tavern-server 管理 API
TAVERN_API_URL=http://localhost:3002/api/v1
# Tavern Admin Token（需与 tavern-server 的 ADMIN_TOKEN 一致）
TAVERN_ADMIN_TOKEN=

# ─── 生产环境（ECS 统一部署 — 仅供参考） ────────────
# VITE_API_BASE_URL=/api/v1
# 构建时通过 --mode production 传入 VITE_API_BASE_URL=/api/v1
# 统一 Nginx 将 /api/ 代理到 Server，同源访问无需跨域

# ─── Docker 构建（可选） ───────────────────────────────
# VITE_API_PROXY_TARGET=http://server:3000
