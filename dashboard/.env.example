# ─── 开发环境 ──────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/api/v1
DATABASE_URL=mysql://root:password@localhost:3306/dashboard

# ─── 生产环境（ECS_100 统一部署） ─────────────────────
# VITE_API_BASE_URL=/api/v1
# 构建时通过 --mode production 传入
# 统一 Nginx 将 /api/ 代理到 Server，同源访问无需跨域
# 构建命令：VITE_API_BASE_URL=/api/v1 npm run build

# ─── Docker 构建（可选） ───────────────────────────────
# VITE_API_PROXY_TARGET=http://server:3000
